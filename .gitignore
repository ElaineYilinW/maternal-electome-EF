# Data — keep on RDSS, never commit
*.pkl
*.pt
*.mat

# Exception: the 6 paper-active EF models in models/ ARE committed
# (small, ~3 MB total, needed for the examples/vignette.ipynb walkthrough)
!models/*.pt

# Exception: the fixed simulated demo data shipped with the vignette
# (one 3-band + one 1-Hz pickle, ~5 MB total, generated by
# examples/generate_demo_data.py)
!examples/demo_data/*.pkl

